# Window Configuration
window-decoration = false
window-padding-x = 12
window-padding-y = 12
background-opacity = 0.92
background-blur-radius = 99

# Scrollback
scrollback-limit = 3023
# Terminal Features
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = always
# Desactiva notificaciones molestas de clipboard o reload
app-notifications = no-clipboard-copy,no-config-reload
# Key Bindings
keybind = ctrl+shift+n=new_window
keybind = ctrl+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
# Shift+Enter para nueva línea (sin ejecutar)
keybind = shift+enter=text:\n

# UI & Theme
# Tema personalizado
theme = vague
# Opacidad de splits no activos
unfocused-split-opacity = 0.7
# Color de splits no activos
unfocused-split-fill = #44464f

# Desactiva barra de título GTK
gtk-titlebar = false
# Solo una instancia de la app
gtk-single-instance = true
# Shell Integration
# Detecta integración con el shell
shell-integration = detect
# Características específicas del shell
shell-integration-features = no-cursor,sudo,no-title

# Fonts
# Fuente principal
font-family = Maple Mono
# Alternativa si usamos Dank Mono:
# Tamaño de fuente
font-size = 14
# Tamaño alternativo para Dank Mono
# font-size = 19

# Estilo de fuente
font-style = Medium

# Características OpenType para la 'a' y ligaduras
font-feature = cv35,cv03,cv05,cv10,cv61

# Cursor
# Estilo de cursor
cursor-style = block
# Shaders
custom-shader-animation = always
custom-shader = ./shaders/cursor_personal.glsl
